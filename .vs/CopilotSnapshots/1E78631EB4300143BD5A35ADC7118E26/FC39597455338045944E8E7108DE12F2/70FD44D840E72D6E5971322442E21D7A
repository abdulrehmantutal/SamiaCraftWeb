        private string BuildCustomerEmail(int OrderID, checkoutBLL data)
        {
            try
            {
                string contentRoot = _webHostEnvironment.ContentRootPath;
                string templatePath = Path.Combine(contentRoot, "Content", "assets", "emailtemplates", "order-customer.txt");

                if (!System.IO.File.Exists(templatePath))
                    return null;

                string body = System.IO.File.ReadAllText(templatePath);
                
                // Build product table
                string itemsTable = BuildItemsTable(data);
                
                // Replace placeholders
                body = body.Replace("#CustomerName#", data.CustomerName);
                body = body.Replace("#Customer#", data.CustomerName);
                body = body.Replace("#OrderNo#", OrderID.ToString());
                body = body.Replace("#OrderDate#", DateTime.UtcNow.AddMinutes(180).ToString("dd MMMM yyyy HH:mm"));
                body = body.Replace("#SubTotal#", $"BHD {(data.AmountTotal ?? 0):0.00}");
                body = body.Replace("#Tax#", $"BHD {(data.Tax ?? 0):0.00}");
                body = body.Replace("#DeliveryAmount#", $"BHD {(data.DeliveryAmount ?? 0):0.00}");
                body = body.Replace("#Discount#", $"BHD {(data.DiscountAmount ?? 0):0.00}");
                body = body.Replace("#GrandTotal#", $"BHD {(data.GrandTotal ?? 0):0.00}");
                body = body.Replace("#Address#", data.Address);
                body = body.Replace("#City#", data.City);
                body = body.Replace("#Contact#", data.ContactNo);
                body = body.Replace("#ContactNo#", data.ContactNo);
                body = body.Replace("#Description#", data.CardNotes);
                body = body.Replace("#PlaceType#", data.PlaceType);
                body = body.Replace("#PaymentType#", GetPaymentTypeName(data.PaymentMethodID));
                body = body.Replace("#items#", itemsTable);
                body = body.Replace("#gifts#", "");

                return body;
            }
            catch (Exception ex)
            {
                return null;
            }
        }

