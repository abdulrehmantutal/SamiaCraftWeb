        public IActionResult Checkout(int id = -1)
        {
            try
            {
                ViewBag.ImageUrl = _configuration["Image"] ?? "https://retail.premium-pos.com";

                var settng = new settingBLL().GetSettings();
                if (settng?.DynamicList?.Count > 0)
