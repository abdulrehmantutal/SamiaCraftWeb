        private async Task<JsonResult> HandleCredimaxPayment(int OrderID, checkoutBLL data)
        {
            try
            {
                SendPendingPaymentEmails(OrderID, data);

                string sessionUrl = "https://credimax.gateway.mastercard.com/api/rest/version/60/merchant/E10561950/session";
                string credentials = "bWVyY2hhbnQuRTEwNTYxOTUwOjhhYTlhZmI5OTg0ODZhMjA0ZjI0ODY0YzIyOTY1OGNh";
                string baseUrl = _configuration["AppSettings:BaseUrl"] ?? "https://localhost:7051";

                ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

                using (var client = new HttpClient())
                {
                    client.DefaultRequestHeaders.Clear();
                    client.DefaultRequestHeaders.Add("Authorization", $"Basic {credentials}");
                    var payload = new
                    {
                        apiOperation = "CREATE_CHECKOUT_SESSION",
                        order = new
                        {
                            amount = (data.GrandTotal ?? 0).ToString("0.00"),
                            currency = "BHD",
                            id = OrderID.ToString()
                        },
                        interaction = new
                        {
                            operation = "PURCHASE",
                            returnUrl = $"{baseUrl}/Order/PaymentCallback?OrderID={OrderID}&status=success",
                            cancelUrl = $"{baseUrl}/Order/PaymentCallback?OrderID={OrderID}&status=cancel",
                            merchant = new
                            {
                                name = "SHAZI TRADING COMPANY WLL",
                                logo = $"{baseUrl}/Content/assets/images/logo.svg"
                            }
                        }
                    };
                    var json = JsonConvert.SerializeObject(payload);
                    var content = new StringContent(json, Encoding.UTF8, "text/plain");

                    var response = await client.PostAsync(sessionUrl, content);
                    if (response.IsSuccessStatusCode)
                    {
                        var responseContent = await response.Content.ReadAsStringAsync();
                        dynamic responseData = JsonConvert.DeserializeObject(responseContent);
                        string sessionID = responseData["session"]["id"];

                        return Json(new
                        {
                            Success = true,
                            orderid = OrderID,
                            orderno = OrderID.ToString(),
                            sessionID = sessionID,
                            redirectUrl = $"https://credimax.gateway.mastercard.com/checkout/pay/{sessionID}?checkoutVersion=1.0.0"
                        });
                    }
                    else
                    {
                        var responseContent = await response.Content.ReadAsStringAsync();
                        return Json(new
                        {
                            Success = false,
                            Message = $"Payment session creation failed: {responseContent}"
                        });
                    }
                }
            }
            catch (Exception ex)
            {
                return Json(new { Success = false, Message = $"Payment error: {ex.Message}" });
            }
        }

        [HttpGet]
        public IActionResult PaymentCallback(int OrderID = 0, string status = "")
        {
            try
            {
                if (status == "success" && OrderID > 0)
                {
                    // Payment approved
                    var checkoutService = new checkoutBLL();
                    checkoutService.OrderUpdate(OrderID, 101); // Update status to completed
                    
                    return RedirectToAction("OrderComplete", new { OrderID = OrderID });
                }
                else
                {
                    // Payment cancelled or failed
                    return RedirectToAction("OrderComplete", new { OrderID = OrderID, OrderNo = "Reject" });
                }
            }
            catch (Exception ex)
            {
                return RedirectToAction("OrderComplete", new { OrderNo = "Reject" });
            }
        }

        /// <summary>
        /// Initializes payment with Benefit Gateway
        /// </summary>
        [HttpGet]
        public IActionResult BenefitPaymentInitialize(int OrderID = 0, double GrandTotal = 0)
        {
            try
            {
                if (OrderID <= 0 || GrandTotal <= 0)
                {
                    return RedirectToAction("OrderComplete", new { OrderNo = "Reject" });
                }

                // Build payment callback URLs
                string baseUrl = _configuration["AppSettings:BaseUrl"] ?? "https://www.samiacrafts.com";
                string responseUrl = $"{baseUrl}/Order/BenefitPaymentResponse";
                string errorUrl = $"{baseUrl}/Order/BenefitPaymentError";

                // Initialize payment request
                var initRequest = new PaymentInitializationRequest
                {
                    OrderID = OrderID,
                    Amount = GrandTotal,
                    ResponseUrl = responseUrl,
                    ErrorUrl = errorUrl
                };

                // Call Benefit Gateway service to initialize payment
                var result = _benefitGatewayService.InitializePayment(initRequest);

                if (result.IsSuccessful && !string.IsNullOrEmpty(result.RedirectUrl))
                {
                    // Redirect to Benefit Gateway payment page
                    return Redirect(result.RedirectUrl);
                }
                else
                {
                    // Payment initialization failed
                    return RedirectToAction("OrderComplete", new { OrderID = OrderID, OrderNo = "Error" });
                }
            }
            catch (Exception ex)
            {
                return RedirectToAction("OrderComplete", new { OrderNo = "Reject" });
            }
        }

        /// <summary>
        /// Processes the response from Benefit Gateway payment page
        /// IMPORTANT: Must return only "REDIRECT=" response as per Benefit Gateway requirements
        /// </summary>
        [HttpPost]
        public IActionResult BenefitPaymentResponse()
        {
            try
            {
                // Create response request from form data
                var paymentResponse = new PaymentResponseRequest
                {
                    TransactionData = Request.Form["trandata"].ToString(),
                    PaymentID = Request.Form["paymentid"].ToString(),
                    TrackID = Request.Form["Trackid"].ToString(),
                    ErrorText = Request.Form["ErrorText"].ToString()
                };

                // Process payment response via Benefit Gateway service
                var result = _benefitGatewayService.ProcessPaymentResponse(paymentResponse);

                if (result.IsSuccessful && result.OrderID > 0)
                {
                    // Payment approved - redirect to completion page
                    string redirectUrl = $"https://www.samiacrafts.com/Order/BenefitPaymentApproved?OrderID={result.OrderID}";
                    return Content($"REDIRECT={redirectUrl}");
                }
                else
                {
                    // Payment failed - redirect to error page
                    return Content("REDIRECT=https://www.samiacrafts.com/Order/OrderComplete?OrderNo=Reject");
                }
            }
            catch (Exception ex)
            {
                // Return only "REDIRECT=" response as required by Benefit Gateway
                return Content("REDIRECT=https://www.samiacrafts.com/Order/OrderComplete?OrderNo=Reject");
            }
        }

