                        Email = orderDetails.Email,
                        ContactNo = orderDetails.ContactNo,
                        Address = orderDetails.Address,
                        City = orderDetails.City,
                        Country = orderDetails.Country,
                        PlaceType = orderDetails.PlaceType,
                        CardNotes = orderDetails.CardNotes,
                        GrandTotal = orderDetails.GrandTotal,
                        AmountTotal = orderDetails.AmountTotal,
                        DiscountAmount = orderDetails.DiscountAmount,
                        Tax = orderDetails.Tax,
                        DeliveryAmount = orderDetails.DeliveryAmount,
                        PaymentMethodID = 3, // BenefitPay
                        OrderDetail = orderDetails.OrderDetail.Select(od => new checkoutBLL.OrderDetails
                        {
                            ID = 0,
                            Name = od.Name,
                            Qty = od.Quantity,
                            Price = od.Price,
