        <div class="text-center mb-5">
            <p class="text-muted mb-2 sec-para">FAQs</p>
            <h2 class="fw-bold sec-heading">Question? <span style="color: var(--addbutton);">Look Here.</span></h2>
        </div>

        <div class="row">
            <div class="col-lg-7">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item mb-3 faq-card">
