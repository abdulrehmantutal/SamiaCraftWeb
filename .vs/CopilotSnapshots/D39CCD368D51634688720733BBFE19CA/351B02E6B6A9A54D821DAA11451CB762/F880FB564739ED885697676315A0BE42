@*-------Product Section-------*@
<div class="porduct-area section-pt section-pb-60 prod-banner">
    <div class="container w-100">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title text-center">
                    <h2 class="main-heading" style="text-align: start; font-weight: 500; font-size: 20px;">Our Products</h2>
                    <div class="d-flex justify-content-between mb-3">
                        <h2 class="main-heading sec-heading">
                            Our <span style="color: var(--addbutton);" class="instagram-text">Top Seller Products</span>
                        </h2>
                        <div class="align-self-center" style="margin-left:auto; padding:1px;">
                            <a href="/Shop/shop" class="btn view-prod">View Products</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="exampleModalCenter">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-default"><span class="font-weight-lighter">Shop by</span> Category</h4>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div style="background-image: url(../../Content/assets/images/kf-bg.jpg); background-size: 100% 100%; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;">
                            <div class="porduct-area section-pt-30 section-pb-30">
                                <div class="container w-100">
                                    <div class="row justify-content-center">
                                        @if (allCategories != null && allCategories.Count > 0)
                                        {
                                            foreach (var item in allCategories)
                                            {
                                                <div class="col-6 col-md-4">
                                                    <div style="background-color: #006783;margin-bottom:10px">
                                                        <div style="top: 10px; left: 10px;">
                                                            <span class="pl-15 pt-10" style="color: white;">
                                                                <a class="mt-10 im" style="font-size: 20px; font-family: Poppins; font-weight: 600; font-stretch: normal; font-style: normal; line-height: normal; letter-spacing: normal;" href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = "", SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})">
                                                                    @item.Title.ToUpper()
                                                                </a>
                                                            </span>
                                                        </div>
                                                        <div class="mobCat" style="position: relative; padding-left: 10px; height: 150px; width: 100%;">
                                                            <a href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = item.CategoryID, SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})">
                                                                <img style="max-width: 100%; height: 100%; position: absolute; bottom: 0; right: 0;" src="@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@item.Image" alt="@item.Title" onerror="this.style.display='none'" />
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row all-products d-flex">
            @if (tenItems != null && tenItems.Count > 0)
            {
                foreach (var item in tenItems)
                {
                    <div class="col-lg-3 col-6 mb-4 pt-3">
                        <div class="position-relative rounded-3 overflow-hidden shadow-sm">
                            <a class="img-a" href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                <img src="@(string.IsNullOrEmpty(item.Image) ? Url.Content("~/Content/assets/images/NA.png") : System.Configuration.ConfigurationManager.AppSettings["Image"].ToString() + item.Image)"
                                     alt="@item.Title"
                                     class="img-fluid rounded-3 shadow-sm"
                                     style="object-fit: cover; width: 100%; aspect-ratio: 1/1;"
                                     onerror="this.style.display='none'" />
                            </a>

                            @if (item.DiscountedPrice != null && item.DiscountedPrice > 0)
                            {
                                <span class="position-absolute top-0 end-0 mt-2 me-2 badge rounded-pill bg-info text-white small px-3 py-1">
                                    @(((item.Price - item.DiscountedPrice) / item.Price * 100).ToString("0"))% off
                                </span>
                            }

                            <div class="hover-icons d-flex flex-column align-items-center">
                                <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })" class="icon-btn" title="Preview">
                                    <img src="~/Content/assets/images/preview.png" alt="Preview">
                                </a>
                                <a onclick="addtoWishlist(@item.ItemID, '@item.Title.Replace("'", " ")', '@item.Image',@item.Price, '@item.InStock.ToString()',1);toast('Item Added to wishlist', 1); return false;" class="icon-btn" title="Wishlist">
                                    <img src="~/Content/assets/images/wishlist.png" alt="Wishlist">
                                </a>

                                @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                                {
                                    <a onclick="addtocart(@item.ItemID,'@item.Title.Replace("'", " ")','@item.Image',@item.Price,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                        <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                    </a>
                                }
                                else
                                {
                                    <a onclick="addtocart(@item.ItemID,'@item.Title.Replace("'", " ")','@item.Image',@item.DiscountedPrice,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                        <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                    </a>
                                }
                            </div>
                        </div>

                        <div class="mt-2 d-flex justify-content-between align-items-center">
                            <small class="text-card fw-semibold">@item.Category</small>
                            <div class="d-flex align-items-center gap-1">
                                @if (item.Stars != null && item.Stars > 0)
                                {
                                    <img class="rating-icon" src="~/Content/assets/images/Star.png" alt="rating">
                                    <span class="fw-semibold rating-number">@item.Stars</span>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#e0e0e0" class="bi bi-star" viewBox="0 0 16 16">
                                        <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.725 3.522-3.361c.33-.32.159-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.38 5.218l-4.898.696c-.441.062-.612.63-.282.95l3.522 3.36-.83 4.726z" />
                                    </svg>
                                    <span class="fw-semibold">0</span>
                                }
                            </div>
                        </div>

                        <h6 class="mb-1 fw-semibold">@item.Title</h6>

                        <div class="d-flex justify-content-between">
                            @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                            {
                                <span class="text-price fw-bold">Rs. @item.Price.ToString("0.00")</span>
                            }
                            else
                            {
                                <span class="text-price fw-bold">Rs. @item.DiscountedPrice?.ToString("0.00")</span>
                                <del class="text-del ms-2">Rs. @item.Price.ToString("0.00")</del>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-md-12 text-center my-4 pt-lg-5">
            <a href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = "", SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})" class="btn btn-default btn-large" tabindex="0"><span>View All</span></a>
        </div>
    </div>
</div>

<section class="new-arrival">
    <h2 class="fw-bold mb-4 text-center" style="font-size: 32px;">
        New Arrival <span style="color: var(--addbutton);">Products</span>
    </h2>

    <div class="container-fluid">
        <div class="row g-4 product-active-lg-4 product-active mt-4">
            @if (newArrivals != null && newArrivals.Count > 0)
            {
                foreach (var item in newArrivals)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card shadow-sm border rounded-4 p-1 h-100" style="font-family: 'Segoe UI', sans-serif;">
                            <div class="row g-3 align-items-center">
                                <div class="col-6 position-relative text-center">
                                    @if (string.IsNullOrEmpty(item.Image))
                                    {
                                        <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                            <img src="~/Content/assets/images/NA.png" alt="@item.Title" class="product-image img-fluid">
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                            <img src="@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@item.Image"
                                                 alt="@item.Title"
                                                 class="product-image img-fluid"
                                                 onerror="this.style.display='none'" />
                                        </a>

                                        <div class="hover-icons d-flex flex-column align-items-center">
                                            <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })" class="icon-btn" title="Preview">
                                                <img src="~/Content/assets/images/preview.png" alt="Preview">
                                            </a>
                                            <a onclick="addtoWishlist(@item.ItemID, '@item.Title.Replace("'", " ")', '@item.Image',@item.Price, '@item.InStock.ToString()',1);toast('Item Added to wishlist', 1); return false;" class="icon-btn" title="Wishlist">
                                                <img src="~/Content/assets/images/wishlist.png" alt="Wishlist">
                                            </a>

                                            @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                                            {
                                                <a onclick="addtocart(@item.ItemID,'@item.Title.Replace("'", " ")','@item.Image',@item.Price,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                                    <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                                </a>
                                            }
                                            else
                                            {
                                                <a onclick="addtocart(@item.ItemID,'@item.Title.Replace("'", " ")','@item.Image',@item.DiscountedPrice,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                                    <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                                </a>
                                            }
                                        </div>
                                    }

                                    @if (item.DiscountedPrice != null && item.DiscountedPrice > 0 && item.Price > item.DiscountedPrice)
                                    {
                                        var discount = Math.Round(100 - ((double)item.DiscountedPrice / (double)item.Price * 100));
                                        <div class="badge bg-info text-white position-absolute top-0 end-0 mt-2 me-2">@discount% off</div>
                                    }
                                </div>

                                <div class="col-6">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="text-card small">@(item.Category ?? "N/A")</span>
                                        <span class="fw-bold d-inline-flex align-items-center p-2">
                                            @if (item.Stars.HasValue && item.Stars > 0)
                                            {
                                                <img class="rating-icon" src="~/Content/assets/images/Star.png" alt="rating">
                                                <span>@item.Stars</span>
                                            }
                                            else
                                            {
                                                <img class="rating-icon" src="~/Content/assets/images/Star.png" alt="rating">
                                                <span>0</span>
                                            }
                                        </span>
                                    </div>

                                    <h6 class="mb-2">@(item.Title ?? "Product")</h6>

                                    <div class="mb-2">
                                        @if (item.DiscountedPrice != null && item.DiscountedPrice > 0)
                                        {
                                            <span class="text-price fw-bold  d-inline-flex align-items-center">Rs. @item.DiscountedPrice</span>
                                            <span class="text-del text-decoration-line-through ms-2">Rs. @item.Price</span>
                                        }
                                        else
                                        {
                                            <span class="text-price fw-bold  d-inline-flex align-items-center">Rs. @item.Price</span>
                                        }
                                    </div>

                                    <p class="text-muted small mb-3">
                                        @(string.IsNullOrEmpty(item.Description) ? "No description available." : item.Description.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                                    </p>

                                    <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })"
                                       class="text-shopnow fw-semibold text-decoration-none d-inline-flex align-items-center">
                                        Shop Now <img class="img-arrow" src="~/Content/assets/images/arrow.png" alt="arrow" />
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

