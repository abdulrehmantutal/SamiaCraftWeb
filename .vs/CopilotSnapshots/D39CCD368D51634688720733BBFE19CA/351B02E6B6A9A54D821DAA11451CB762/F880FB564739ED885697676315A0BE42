@{
    ViewData["Title"] = "Home Page";
    ViewBag.Title = "Home Page";
    var categoryList = (List<samiacraft.Models.BLL.categoryBLL>)(ViewBag.categoryList ?? new List<samiacraft.Models.BLL.categoryBLL>());
    var tenItems = (List<samiacraft.Models.BLL.itemBLL>)(ViewBag.TenItems ?? new List<samiacraft.Models.BLL.itemBLL>());
    var newArrivals = (List<samiacraft.Models.BLL.itemBLL>)(ViewBag.NewArrivals ?? new List<samiacraft.Models.BLL.itemBLL>());
    var reviews = (List<samiacraft.Models.BLL.reviewBLL>)(ViewBag.Reviews ?? new List<samiacraft.Models.BLL.reviewBLL>());
    var allCategories = (List<samiacraft.Models.BLL.categoryBLL>)(ViewBag.Category ?? new List<samiacraft.Models.BLL.categoryBLL>());
}

@*-------Occasion Section-------*@
<section class="occasion py-5 text-center" style="background-color: #fff;">
    <p class="text-muted mb-1" style="color:var(--addbutton);">Occasions</p>
    <h2 class="fw-bold mb-4">
        Shop By <span style="color: var(--addbutton);">Occasions</span>
    </h2>

    <div class="container">
        <div class="row justify-content-center g-4">
            @if (categoryList != null && categoryList.Count > 0)
            {
                foreach (var item in categoryList)
                {
                    <div class="col-4 col-sm-4 col-md-2 col-lg-2">
                        <a href="@Url.Action("shop", "shop", new {
                              Category = "",
                              CategoryIDs = item.CategoryID,
                              SubCategoryIDs = "",
                              ColorIDs = "",
                              MinPrice = "RS0",
                              MaxPrice = "RS50000",
                              Searchtext = "",
                              SortID = 0
                              })" class="text-decoration-none">
                            <div class="category-circle mx-auto d-flex align-items-center justify-content-center shadow-sm overflow-hidden">
                                @if (!string.IsNullOrEmpty(item.Image))
                                {
                                    <img src="@(System.Configuration.ConfigurationManager.AppSettings["Image"]?.ToString() + item.Image)"
                                         alt="@(item.Title ?? "Category")"
                                         class="img-fluid" style="max-width: 70%; max-height: 70%; object-fit: contain;" />
                                }
                                else
                                {
                                    <img src="~/Content/assets/images/NA.png"
                                         alt="@(item.Title ?? "Category")"
                                         class="img-fluid" style="max-width: 70%; max-height: 70%; object-fit: contain;" />
                                }
                            </div>
                            <span class="d-block mt-2 text-dark fw-medium">@(item.Title ?? "Category")</span>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

@*-------Hero Section-------*@
<section class="hero-slider hero-slider-one desktop-banner">
    @if (ViewBag.Banner != null && ViewBag.Banner.Count > 0)
    {
        foreach (var item in ViewBag.Banner)
        {
            <div class="single-slide d-flex align-items-center bg-cover bg-center">
                <img loading="lazy"
                     style="width:100%; object-fit:cover;"
                     src="@(System.Configuration.ConfigurationManager.AppSettings["Image"] + "/" + item.Image)"
                     alt="@item.Title"
                     title="@item.Title"
                     onerror="this.style.display='none'" />
            </div>
        }
    }
</section>

<section class="hero-slider hero-slider-one mobile-banner">
    @if (ViewBag.MobileBanner != null && ViewBag.MobileBanner.Count > 0)
    {
        foreach (var item in ViewBag.MobileBanner)
        {
            <div class="single-slide d-flex align-items-center bg-cover bg-center">
                <img loading="lazy"
                     style="width:100%; object-fit:cover;"
                     src="@(System.Configuration.ConfigurationManager.AppSettings["Image"] + "/" + item.Image)"
                     alt="@item.Title"
                     title="@item.Title"
                     onerror="this.style.display='none'" />
            </div>
        }
    }
</section>

<div class="deal-row"></div>

<div id="mySidenav" class="sidenav border shadow">
    <div class="d-flex justify-content-between">
        <div class="px-3"><h5> </h5></div>
        <div class="px-3">
            <a href="javascript:void(0)" class="closebtn" onclick="closeNav()">&times;</a>
        </div>
    </div>
    <div class="off-canvas-inner">
        <div class="mobile-navigation side-navigation">
            <nav class="feature px-3">
                <div class="shop-sidebar">
                    <h4 class="">FILTER BY TEXT</h4>
                </div>
                <div class="input-group input-group-sm my-4">
                    <input type="text" class="form-control Seachtxt" placeholder="Search" aria-label="Search" aria-describedby="basic-addon2">
                    <div class="input-group-append">
                        <a href="javascript:;" class="filterOn btn btn-default-opposite btn-small">Search</a>
                    </div>
                </div>
                <div class="shop-sidebar mb-4 pt-1">
                    <div class="d-flex justify-content-between">
                        <div class=""><h4 class="title">CATEGORIES</h4></div>
                        <div class="">
                            <a href="javascript:;" class="filterOn"><i class="ion-ios-search-strong"></i></a>
                        </div>
                    </div>
                    <ul class="scroll-style">
                        @if (allCategories != null && allCategories.Count > 0)
                        {
                            foreach (var item in allCategories)
                            {
                                <li><label><input type="checkbox" name="Category" class="mr-2" value="@item.CategoryID">@item.Title</label></li>
                            }
                        }
                    </ul>
                </div>
            </nav>
        </div>
    </div>
</div>

<script>
    function openNav() {
        document.getElementById("mySidenav").style.width = "305px";
    }
    function closeNav() {
        document.getElementById("mySidenav").style.width = "0";
    }
</script>

@*-------About us Section-------*@
