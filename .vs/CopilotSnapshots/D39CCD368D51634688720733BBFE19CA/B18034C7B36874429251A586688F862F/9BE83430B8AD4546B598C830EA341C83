    <style>
    :root {
        --headertoparea: @(headertoparea) !important;
        --logo: url('@(logo)');
        --bgworkflow: url('@(workflow)');
        --bgfeaturedproduct: url('@(featured)');
        --bgpopularproduct: url('@(popular)');
        --bgnewarrivals: url('@(newarrival)');
        --bgtestimonials: url('@(testimonial)');
        --bgnewsletter: url('@(newsletter)');
        --addbutton: @(addbutton);
    }

    .btn-default-opposite {
        color: white !important;
        background-color: var(--addbutton);
        border-color: var(--addbutton);
    }

        .btn-default-opposite:hover {
            color: var(--addbutton);
            background-color: #ffffff !important;
            border-color: var(--addbutton);
        }

        .nav-bg {
            background-color: white !important;
            transition: .3s all ease-out;
        }

        @@media only screen and (max-width: 479px) {
            .container-topheader {
                width: 100% !important;
            }
        }

        .prod-detail img {
            height: auto;
            width: 100%;
            object-fit: contain;
            margin: auto;
        }

        @@media only screen and (max-width: 480px) {
            .Feature-tiem > a img, .product-image > a img {
                height: auto;
                min-height: 165px;
                max-height: 165px;
            }

            .shop-item > a img {
                height: auto !important;
                min-height: 165px;
                max-height: 165px;
            }
        }

        .hovereffect {
            width: 100%;
            overflow: hidden;
            position: relative;
            text-align: center;
            cursor: default;
            border-radius: 5px;
        }

            .hovereffect:hover img {
                -ms-transform: scale(2.2);
                -webkit-transform: scale(2.2);
                transform: scale(2.2);
            }

            .hovereffect img {
                display: block;
                position: relative;
                -webkit-transition: all .4s linear;
                transition: all 1.2s linear;
            }

        #cart-total {
            background: var(--addbutton);
        }

        .newsletter-footer .subscribe-btn {
            background: var(--addbutton);
        }

        .btn-newsletter {
            background: var(--addbutton);
            border: 1px solid var(--addbutton);
        }

        .text-default {
            color: var(--addbutton);
        }

        .main-menu-area ul > li:first-child {
            color: #16563B;
        }

        #scrollUp {
            background-color: var(--addbutton);
        }

        .breadcrumb-area h2 {
            color: var(--addbutton);
        }

        .breadcrumb-list .breadcrumb-item.active {
            color: var(--addbutton);
        }

        a:hover {
            color: var(--addbutton);
        }

        .product-rating li {
            color: var(--addbutton);
        }

        .mini-cart-btns .cart-btns a {
            background: var(--addbutton);
            border: 2px solid var(--addbutton);
        }

            .mini-cart-btns .cart-btns a:hover {
                background: white;
                border: 2px solid var(--addbutton);
                color: var(--addbutton);
            }

        .fill {
            color: var(--addbutton);
        }

            .fill:hover {
                color: red;
            }

    .imgcon .wl {
        position: absolute;
        top: 0;
        right: 0;
        z-index: 2; /* add this to make icon stack over image */
        margin-right: 8px;
        margin-top: 8px;
        border: 1px solid var(--addbutton);
        justify-content: center;
        border-radius: 50%;
        height: 30px;
        width: 30px;
        padding-top: 1%;
    }

        .social-top ul {
            list-style: none; /* remove bullets */
            margin: 0;
            padding: 0;
            display: flex; /* align in one row */
            justify-content: flex-end; /* push them to right */
            gap: 10px;
        }

        .social-top ul li {
            display: inline-block;
            margin-right: 2px !important;
        }

        .parent {
            height: 100vh;
        }

            .parent > .row {
                display: flex;
                align-items: center;
                height: 100%;
            }

        .col img {
            height: 100px;
            width: 100%;
            cursor: pointer;
            transition: transform 1s;
            object-fit: cover;
        }

        .col label {
            overflow: hidden;
            position: relative;
        }

        .imgbgchk:checked + label > .tick_container {
            opacity: 1;
        }
        /*         aNimation */
        .imgbgchk:checked + label > img {
            transform: scale(1);
            opacity: 0.3;
        }

        .tick_container {
            transition: .5s ease;
            opacity: 0;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            -ms-transform: translate(-50%, -50%);
            cursor: pointer;
            text-align: center;
        }

        .tick {
            background-color: #4CAF50;
            color: white;
            font-size: 16px;
            padding: 6px 12px;
            height: 40px;
            width: 40px;
            border-radius: 100%;
        }

        .image-container {
            margin-bottom: 10px; /* Adjust the margin as needed */
        }

            .image-container img {
                max-width: 100%; /* Make sure the image doesn't exceed its container */
            }


        .figure {
            position: relative;
            /*width: 360px;*/ /* can be omitted for a regular non-lazy image */
            max-width: 100%;
        }

            .figure img.Sirv.image-hover {
                position: absolute;
                top: 0;
                right: 0;
                left: 0px;
                bottom: 0;
                object-fit: contain;
                opacity: 0;
                transition: opacity .2s;
            }

            .figure:hover img.Sirv.image-hover {
                opacity: 1;
            }



        #popupModal {
            /*background-color: transparent;*/
            backdrop-filter: blur(70px);
        }

        .modal-content {
            background-color: rgba(255, 255, 255, 0.8); /* Add a semi-transparent background for better readability */
            backdrop-filter: blur(10px); /* Adjust the blur intensity as needed */
            border: 1px solid rgba(255, 255, 255, 0.8); /* Add a border to enhance visibility */
        }

        /* Other styles remain unchanged */


        @@media only screen and (max-width: 480px) {
            .citymobile {
                padding-top: 50px !important;
                padding-bottom: 50px !important;
            }

            .figure img.Sirv.image-hover {
                position: absolute;
                top: 0;
                right: 0;
                left: 0px;
                bottom: 0;
                object-fit: contain;
                opacity: 0;
                transition: opacity .2s;
                height: 50px;
            }

            .image-container img {
                max-width: 90%;
            }

            .citycol {
                width: 33.33%;
            }

            .cityvw {
                font-size: 15px !important;
            }
        }

        .modal-dialog {
            min-height: calc(100vh - 60px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: auto;
        }

        @@media(max-width: 768px) {
            .modal-dialog {
                min-height: calc(100vh - 20px);
            }
        }

        @@media (min-width: 992px) {
            .hidedesktop {
                display: none !important;
            }
        }
    </style>


