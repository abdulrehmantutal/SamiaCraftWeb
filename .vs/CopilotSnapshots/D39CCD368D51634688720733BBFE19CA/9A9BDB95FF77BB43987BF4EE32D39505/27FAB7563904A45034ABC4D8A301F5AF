@{
    ViewBag.Title = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .btn-default {
        color: white !important;
        background-color: var(--addbutton);
        border-color: var(--addbutton);
    }

        .btn-default:hover {
            color: var(--addbutton);
            background-color: white !important;
            border-color: var(--addbutton);
        }

    .btn::before, .btn-2::before {
        position: absolute;
        left: 50%;
        top: 50%;
        height: 0;
        width: 150%;
        background-color: white;
        color: #000 !important;
        transition: all 0.3s ease 0s;
        content: "";
        transform: translateX(-50%) translateY(-50%) rotate(-10deg);
        opacity: 0;
        z-index: -1;
    }

    .shop-item-filter-list li .active {
        color: var(--addbutton);
    }

    .imgcon .wl {
        position: absolute;
        top: 0;
        right: 0;
        z-index: 2; /* add this to make icon stack over image */
        margin-right: 8px;
        margin-top: 8px;
        border: 1px solid var(--addbutton);
        justify-content: center;
        border-radius: 50%;
        height: 30px;
        width: 30px;
        padding-top: 1%;
    }

    .fill {
        color: var(--addbutton);
    }

    .add-button {
        margin-top: 5% !important;
        background-color: var(--addbutton);
        border: none;
        border-radius: 50%;
        color: white;
        font-weight: 500;
        cursor: pointer;
        padding: 7px 15px;
        transition: background-color 0.3s ease-in-out;
    }

        .add-button:hover {
            background-color: white !important;
            border: 1px solid var(--addbutton);
        }

            .add-button:hover .add-icon {
                color: black !important;
            }

    .product-content .price-box .new-price {
        color: var(--addbutton);
    }

    .shop-sidebar h4::before {
        position: absolute;
        content: "";
        background: var(--addbutton);
        width: 50px;
        height: 2px;
        left: 0;
        bottom: -1px;
    }

    .ui-widget-content .ui-slider-range {
        background: var(--addbutton);
    }

    .ui-widget-content .ui-state-default:hover {
        background: var(--addbutton);
    }

    .ui-widget-content .ui-state-default {
        background: #ffffff;
        border: 3px solid var(--addbutton);
        border-radius: 25px;
        box-shadow: none;
        color: #ffffff;
        cursor: pointer;
        font-weight: normal;
        height: 15px;
        width: 15px;
    }

    .pagination li.active a {
        color: #ffffff;
        background: var(--addbutton);
        border: 1px solid var(--addbutton);
    }

    .pagination li a:hover {
        color: #ffffff !important;
        background: var(--addbutton);
        border: 1px solid var(--addbutton);
    }
</style>

@if (ViewBag.Banner != null && ViewBag.Banner.Count > 0)
{
    <!-- Desktop Banner -->
    <div class="breadcrumb-area section-ptb desktop-banner"
         style="background: url(@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@ViewBag.Banner[0].Image) repeat scroll 0 0; background-size: cover;">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h2 class="breadcrumb-title">@ViewBag.Banner[0].MainHeading</h2>
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="~/home/index">Home</a></li>
                        <li class="breadcrumb-item active">Shop</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

@if (ViewBag.MobileBanner != null && ViewBag.MobileBanner.Count > 0)
{
    <!-- Mobile Banner -->
    <div class="breadcrumb-area section-ptb mobile-banner"
         style="background: url(@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@ViewBag.MobileBanner[0].Image) repeat scroll 0 0; background-size: cover;">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h2 class="breadcrumb-title">@ViewBag.MobileBanner[0].MainHeading</h2>
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="~/home/index">Home</a></li>
                        <li class="breadcrumb-item active">Shop</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else if ((ViewBag.Banner == null || ViewBag.Banner.Count == 0) &&
         (ViewBag.MobileBanner == null || ViewBag.MobileBanner.Count == 0))
{
    <!-- Fallback Default -->
    <div class="breadcrumb-area section-ptb">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h2 class="breadcrumb-title">Online Flower Shop</h2>
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="~/home/index">Home</a></li>
                        <li class="breadcrumb-item active">Shop</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}


