                                        <img src="~/Content/assets/images/NA.png" alt="@item.Title" class="product-image img-fluid">
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                        <img src="@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@item.Image"
                                             alt="@item.Title"
                                             class="product-image img-fluid">
                                    </a>

                                    @*--Hover Icons--*@
                                    <div class="hover-icons d-flex flex-column align-items-center">
                                        <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })" class="icon-btn" title="Preview">
                                            <img src="~/Content/assets/images/preview.png" alt="Preview">
                                        </a>
                                        <a onclick="addtoWishlist(@item.ItemID, '@item.Title', '@item.Image',@item.Price, '@item.InStock.ToString()',1);toast('Item Added to wishlist', 1); return false; " class="icon-btn" title="Wishlist">
                                            <img src="~/Content/assets/images/wishlist.png" alt="Wishlist">
                                        </a>

                                        @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                                        {
                                            <a onclick="addtocart(@item.ItemID,'@item.Title','@item.Image',@item.Price,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                                <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                            </a>
                                        }
                                        else
                                        {
                                            <a onclick="addtocart(@item.ItemID,'@item.Title','@item.Image',@item.DiscountedPrice,1);toast('Item Added to Cart', 1); return false;" class="icon-btn" title="Add to Cart">
                                                <img src="~/Content/assets/images/addcart.png" alt="Add to Cart">
                                            </a>
                                        }


                                    </div>



                                }

                                <!-- Discount Badge -->
                                @if (item.DiscountedPrice != null && item.DiscountedPrice > 0 && item.Price > item.DiscountedPrice)
                                {
                                    var discount = Math.Round(100 - ((double)item.DiscountedPrice / (double)item.Price * 100));
                                    <div class="badge bg-info text-white position-absolute top-0 end-0 mt-2 me-2">@discount% off</div>
                                }
                            </div>

                            <!-- Content Column -->
                            <div class="col-6">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-card small">@item.Category</span>
                                    <span class="fw-bold d-inline-flex align-items-center p-2">
                                        <img class="rating-icon" src="~/Content/assets/images/Star.png" alt="rating">
                                        @item.Stars
                                    </span>
                                </div>

                                <h6 class="mb-2">@item.Title</h6>

                                <div class="mb-2">
                                    @if (item.DiscountedPrice != null && item.DiscountedPrice > 0)
                                    {
                                        <span class="text-price fw-bold  d-inline-flex align-items-center">Rs. @item.DiscountedPrice</span>
                                        <span class="text-del text-decoration-line-through ms-2">Rs. @item.Price</span>
                                    }
                                    else
                                    {
                                        <span class="text-price fw-bold  d-inline-flex align-items-center">Rs. @item.Price</span>
                                    }
                                </div>

                                <p class="text-muted small mb-3">
                                    @(string.IsNullOrEmpty(item.Description)
                                ? "No description available."
                                : item.Description.Length > 60
                                    ? item.Description.Substring(0, 60) + "..."
                                    : item.Description)
                                </p>

                                <a href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })"
                                   class="text-shopnow fw-semibold text-decoration-none d-inline-flex align-items-center">
                                    Shop Now <img class="img-arrow" src="~/Content/assets/images/arrow.png" alt="arrow" />
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

