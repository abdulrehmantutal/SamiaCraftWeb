<div class="porduct-area section-pt section-pb-60 prod-banner">
    <div class="container w-100">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title text-center">
                    <div class="d-flex justify-content-between mb-3 ">
                        <div class="p-2"><h2 class=" "><span class="font-weight-lighter">All</span> Products</h2></div>
                        <div class="align-self-center " style="margin-left:auto; padding:1px;">
                            <button style="font-size: 14px;cursor: pointer;padding: 4px 15px;" class="bold border border-dark btn btn-default-opposite shadow-sm" data-toggle="modal" data-target="#exampleModalCenter"><i class="ion-android-list mr-1"></i> <span>Category</span></button>
                        </div>
                        <div class="align-self-center ">
                            <a style="font-size: 14px;cursor: pointer;padding: 4px 15px;" class="bold border border-dark btn btn-default-opposite shadow-sm" onclick="openNav()"><i class="ion-funnel mr-1"></i> <span>Filter</span></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="exampleModalCenter">
            <div class="modal-dialog">
                <div class="modal-content">
                   <!-- Modal Header -->
                    <div class="modal-header">
                        <h4 class="modal-title text-default"><span class="font-weight-lighter">Shop by</span> Category</h4>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>

                    <!-- Modal body -->
                    <div class="modal-body">
                        <div style="background-image: url(../../Content/assets/images/kf-bg.jpg); background-size: 100% 100%; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;">
                            <div class="porduct-area section-pt-30 section-pb-30 ">
                                <div class="container w-100 ">

                                    <div class="row justify-content-center ">
                                        @foreach (var item in ViewBag.Category)
                                        {
                                            <div class="col-6 col-md-4">
                                                <div style="background-color: #006783;margin-bottom:10px">
                                                    <div class="" style="top: 10px; left: 10px;">
                                                        <h6 class="pl-15 pt-10" style="color: white;">
                                                            <a class="mt-10 im" style="font-size: 20px; font-family: Poppins; font-weight: 600; font-stretch: normal; font-style: normal; line-height: normal; letter-spacing: normal;" href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = "", SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})">
                                                                @item.Title.ToUpper()
                                                            </a>
                                                        </h6>
                                                    </div>
                                                    <div class="mobCat" style="position: relative; padding-left: 10px; height: 150px; width: 100%;">
                                                        <a href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = item.CategoryID, SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})">
                                                            <img style="max-width: 100%; height: 100%; position: absolute; bottom: 0; right: 0;" src="@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@item.Image" alt="" />
                                                        </a>
                                                    </div>

                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row all-products d-flex ">
            @foreach (var item in ViewBag.TenItems)
            {
                <div class="col-lg-12 col-12 ">
                    <div class="single-product-wrap" style="box-shadow: rgba(99, 99, 99, 0.2) 0px 2px 8px 0px;">
                        <div class="product-image card hovereffect imgcon">
                            @if (item.Image == "" || item.Image == null)
                            {
                                <a class="img-a" href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                    <img src="~/Content/assets/images/NA.png" alt="@item.Title">
                                </a>
                                <a class="wl" onclick="addtoWishlist(@item.ItemID, '@item.Title', '@item.Image',@item.Price, '@item.InStock.ToString()',1);toast('Item Added to wishlist', 1); return false; "><i class="ion-android-favorite-outline fill"></i></a>
                            }
                            else
                            {
                                <a class="img-a" href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })">
                                    <img src="@System.Configuration.ConfigurationManager.AppSettings["Image"].ToString()@item.Image" alt="@item.Title">
                                </a>
                                <a class="wl" onclick="addtoWishlist(@item.ItemID, '@item.Title', '@item.Image',@item.DiscountedPrice, '@item.InStock.ToString()',1);toast('Item Added to wishlist', 1); return false; "><i class="ion-android-favorite-outline fill"></i></a>
                            }
                        </div>

                        <div class="row" style="padding: 0px 10px 10px 10px; ">
                            <div class="col-8">
                                <div class="mt-0  product-content">
                                    <p class="mob" style="text-align:left;"> <a class="mob" style="font-size: 18px; font-weight: 700" href="@Url.Action("ProductDetails", "Product", new { ItemID = item.ItemID })"> @item.Title </a></p>

                                    @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                                    {
                                        <div class="price-box" style="text-align:left;">
                                            <span style="font-weight: 600" class="currency-text mx-0 text-default"></span><span style="font-weight: 600" class="new-price mx-0">@item.Price</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="price-box" style="text-align:left; ">
                                            <span class="currency-text mx-0"></span><span class="old-price mx-0">@item.Price</span>
                                            <span class="currency-text mx-0 text-default"></span><span class="new-price mx-0">@item.DiscountedPrice</span>
                                        </div>
                                    }

                                    <div class="pro_rating">
                                        <ul class="product-rating m-auto d-flex">
                                            @{
                                                if (item.Stars != null)
                                                {
                                                    for (int i = 0; i < item.Stars; i++)
                                                    {
                                                        <li><span class="ion-android-star"></span></li>
                                                    }
                                                    for (int i = 0; i < (5 - item.Stars); i++)
                                                    {
                                                        <li><span class="ion-android-star-outline"></span></li>
                                                    }
                                                }
                                                else
                                                {
                                                    <li><span class="ion-android-star-outline"></span></li>
                                                    <li><span class="ion-android-star-outline"></span></li>
                                                    <li><span class="ion-android-star-outline"></span></li>
                                                    <li><span class="ion-android-star-outline"></span></li>
                                                    <li><span class="ion-android-star-outline"></span></li>
                                                }
                                            }
                                        </ul>
                                    </div>


                                </div>
                            </div>
                            <div class="col-4" style="text-align:right;">
                                <div class="mobview">
                                    @if (item.DiscountedPrice == null || item.DiscountedPrice == 0)
                                    {
                                        <button class="add-button" onclick="addtocart(@item.ItemID,'@item.Title','@item.Image',@item.Price,1);toast('Item Added to Cart', 1); return false;">
                                            <span class="ion-android-add add-icon"></span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="add-button" onclick="addtocart(@item.ItemID,'@item.Title','@item.Image',@item.DiscountedPrice,1);toast('Item Added to Cart', 1); return false;">
                                            <span class="ion-android-add add-icon"></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>


        <div class="col-md-12 text-center my-4 pt-lg-5">
            <a href="@Url.Action("shop", "shop", new { Category = "", CategoryIDs = "", SubCategoryIDs = "",ColorIDs = "",MinPrice = "RS0",MaxPrice = "RS50000",Searchtext = "",SortID=0})" class="btn btn-default  btn-large" tabindex="0"><span>View All</span></a>
