<style>
    .hero-slider-one .slider-text-info h1, .hero-slider-two .slider-text-info h1 {
        color: var(--addbutton);
    }

    .newsletter-icon {
        color: white !important;
    }

    .product-content .price-box .new-price {
        color: var(--addbutton);
    }

    .btn-newsletter {
        background: var(--addbutton);
        border: 1px solid var(--addbutton);
    }

    .btn-default:hover {
        color: var(--addbutton);
