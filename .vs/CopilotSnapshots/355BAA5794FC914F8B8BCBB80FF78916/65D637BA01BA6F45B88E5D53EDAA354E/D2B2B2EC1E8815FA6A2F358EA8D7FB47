<style>


    .coupon-accordion h3 {
        background: #f6f6f6;
        border-top: 3px solid var(--addbutton);
        color: #515151;
        font-size: 14px;
        font-weight: 400;
        margin: 0 0 30px;
        padding: 1em 2em 1em 3.5em;
        position: relative;
        text-transform: capitalize;
    }

    .btn-place-order {
        background: var(--addbutton);
        border: medium none;
        color: #ffffff !important;
        font-size: 14px;
        font-weight: 600;
        text-align: center;
        padding: 12px;
        text-transform: uppercase;
        width: 100%;
        -webkit-transition: 0.4s;
        transition: 0.4s;
    }

    .coupon-accordion h3 .coupon {
        color: var(--addbutton);
        cursor: pointer;
        -webkit-transition: 0.4s;
        transition: 0.4s;
    }


    .hide {
        display: none;
    }



    @@media (min-width: 767px) {

        .desktop-payments {
            display: block;
        }

        .mobile-payments {
            display: none;
        }
    }

        @@media (max-width: 767px) {
            .desktop-payments {
                display: none;
            }

            .mobile-payments {
                display: block;
            }
        }
</style>

