        public ActionResult HBLPaymentApproved(string data = "",int OrderID = 0)
        {
            try
            {
                if (!string.IsNullOrEmpty(data))
                {
                    RSA rsa = new RSA();
                    string private_key = "<RSAKeyValue><Modulus></Modulus><Exponent>AQAB</Exponent><P></P><Q></Q><DP></DP><DQ></DQ><InverseQ></InverseQ><D></D></RSAKeyValue>";
                    // string private_key = "";

                    data = data.Replace(" ", "+");
                    int mod4 = data.Length % 4;
                    if (mod4 > 0)
                    {
                        data += new string('=', 4 - mod4);
                    }
                    data = rsa.DeCrypt(private_key, data, 4096);
                    //data = data.Replace("&", "--");
                    string[] array = data.ToString().Split('&');
                    var responseCode = array[0].Split('=')[1];
                    var responseRefNo = array[2].Split('=')[1];

                    OrderPaymentLogger.Log(OrderID, null, "HBLPayment", null, "HBLResponseDecrypted", null, data);


                    if (responseCode == "100" && responseRefNo != "0" && responseRefNo != "")
                    {
                        return RedirectToAction("OrderComplete", "Order", new { OrderID = responseRefNo });
                    }
                    else
                    {
                        return RedirectToAction("OrderComplete", "Order", new { OrderNo = "Reject" });
                    }
                }
                return RedirectToAction("OrderComplete", "Order", new { OrderNo = "Reject" });
            }
            catch(Exception ex)
            {
                OrderPaymentLogger.Log(OrderID, null, "HBLPayment", null, "Error", null, null, ex.Message);
                return RedirectToAction("OrderComplete", "Order", new { OrderNo = "Reject" });
            }
        }
