        #region api calling
        public string CallService(string jsonData, int orderID, int customerID, string paymentMethod)
        {
            string URL = "https://digitalbankingportal.hbl.com/hostedcheckout/api/checkout";
            string AllowProxy = System.Configuration.ConfigurationSettings.AppSettings["AllowProxy"];
            string Proxy = System.Configuration.ConfigurationSettings.AppSettings["Proxy"];
            //new line of code
            ServicePointManager.Expect100Continue = true;
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls
                   | SecurityProtocolType.Tls11
                   | SecurityProtocolType.Tls12
                   | SecurityProtocolType.Ssl3;

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(URL);
            WebProxy proxy = new WebProxy(Proxy, true);
            HBLPayResponseModel hblResponse = new HBLPayResponseModel();


            request.Method = "POST";
            request.ContentType = "application/json";

            OrderPaymentLogger.Log(orderID, customerID, paymentMethod, null, "RequestSent", jsonData);

            if (AllowProxy == "1")
                request.Proxy = proxy;
            request.ContentLength = jsonData.Length;
            try
            {
                using (Stream webStream = request.GetRequestStream())
                using (StreamWriter requestWriter = new StreamWriter(webStream, System.Text.Encoding.ASCII))
                {
                    requestWriter.Write(jsonData);
                }


                string finalResult = "";
                string sessionId = null;

                WebResponse webResponse = request.GetResponse();
                using (Stream webStream = webResponse.GetResponseStream())
                {
                    if (webStream != null)
                    {
                        using (StreamReader responseReader = new StreamReader(webStream))
                        {
                            string response = responseReader.ReadToEnd();
                            finalResult = response;
                        }
                    }
                }
                hblResponse = JsonConvert.DeserializeObject<HBLPayResponseModel>(finalResult);

                if (hblResponse.Data != null && !string.IsNullOrEmpty(hblResponse.Data.SESSION_ID))
                {
   
                    sessionId = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(hblResponse.Data.SESSION_ID));
                    hblResponse.Data.SESSION_ID = sessionId; 
                }

                finalResult = JsonConvert.SerializeObject(hblResponse);

                OrderPaymentLogger.Log(orderID, customerID, paymentMethod, sessionId, "ResponseReceived", null, finalResult);

                return finalResult;
            }

            catch (WebException ex)
            {
                string resp = string.Empty;

                if (ex.Response != null)
                {
                    StreamReader sr = new StreamReader(ex.Response.GetResponseStream());
                    resp = sr.ReadToEnd();
                }
                else
                {
                    resp = ex.Message;
                }

                OrderPaymentLogger.Log(orderID, customerID, paymentMethod, "No Session", "Error", jsonData, resp, resp);
                throw new Exception(resp);
            }
        }

