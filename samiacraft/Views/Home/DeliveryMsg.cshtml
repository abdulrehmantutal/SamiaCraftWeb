@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <style>
        .maintenance {
            background-image: url(https://demo.wpbeaveraddons.com/wp-content/uploads/2018/02/main-1.jpg);
            background-repeat: no-repeat;
            background-position: center center;
            background-attachment: scroll;
            background-size: cover;
        }

        .maintenance {
            width: 100%;
            height: 100%;
            min-height: 100vh;
            display: flex;
            flex-flow: column nowrap;
            justify-content: center;
            align-items: center;
        }

        .maintenance_contain {
            display: flex;
            flex-direction: column;
            flex-wrap: nowrap;
            align-items: center;
            justify-content: center;
            padding: 15px;
        }

            .maintenance_contain img {
                width: auto;
                max-width: 100%;
            }

        .pp-infobox-title-prefix {
            font-weight: 500;
            font-size: 20px;
            color: #36b5ae;
            margin-top: 30px;
            text-align: center;
            font-family: sans-serif;
        }

        .pp-infobox-title {
            color: #36b5ae;
            font-family: sans-serif;
            font-weight: 700;
            font-size: 40px;
            margin-top: 10px;
            margin-bottom: 10px;
            text-align: center;
            display: block;
            word-break: break-word;
        }

        .pp-infobox-description {
            color: #000000;
            font-family: "Poppins", sans-serif;
            font-weight: 400;
            font-size: 18px;
            text-align: center;
        }

            .pp-infobox-description p {
                margin: 0;
            }

        .title-text.pp-primary-title {
            color: #000000;
            font-family: sans-serif;
            font-weight: 500;
            font-size: 18px;
            line-height: 1.4;
            margin-top: 50px;
        }

        .pp-social-icon {
            margin: 10px;
            display: inline-block;
            text-align: center;
        }

            .pp-social-icon a {
                display: inline-block;
                height: 40px;
                width: 40px;
            }

                .pp-social-icon a i {
                    border-radius: 100px;
                    font-size: 20px;
                    height: 40px;
                    width: 40px;
                    line-height: 40px;
                    text-align: center;
                }

                .pp-social-icon a i {
                    color: #36b5ae;
                    border: 2px solid #36b5ae;
                }

        .pp-social-icons {
            display: flex;
            flex-flow: row wrap;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="maintenance" style="background: linear-gradient(135deg, #e4f9f8, #d4f1f0); min-height: 100vh; display: flex; justify-content: center; align-items: center; padding: 40px;">
        <div class="maintenance_contain" style="text-align: center; max-width: 600px; background-color: #ffffffcc; padding: 40px 30px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">

            <!-- New Logo -->
            <img src="~/Content/assets/images/logo/karachi-flora.svg" alt="My Logo" style="width: 160px; margin-bottom: 20px;">

            <span class="pp-infobox-title-prefix">
                TEMPORARILY UNAVAILABLE
            </span>

            <div class="pp-infobox-title-wrapper">
                <h3 class="pp-infobox-title" style="font-size: 26px; margin: 10px 0;">
                    We're Taking a Short Break for Eid 🌙
                </h3>
            </div>

            <div class="pp-infobox-description" style="font-size: 17px; color: #444;">
                <p>
                    Thank you for visiting <strong>Al Hilal</strong>.
                    We're currently not accepting orders due to Eid Holidays.
                </p>
                <p>
                    We'll resume our blooming deliveries  <strong>Very Soon</strong>.
                    Wishing you a joyful Eid!
                </p>
            </div>

            <a href="/" style="display:inline-block; margin-top: 25px; background-color: #36b5ae; color: #fff; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 500;">
                🌸 Return to Homepage
            </a>
        </div>
    </div>
</body>
</html>
