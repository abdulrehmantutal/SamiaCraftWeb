                                        }
                                        else
                                        {
                                            <span style="font-size:13px; font-weight:700; color:#1C3D5A; font-family:'Segoe UI',sans-serif;">BHD @item.Price.ToString("0.00")</span>
                                        }
                                    </div>

                                    <!-- Description -->
                                    <p style="font-size:11px; color:#888; line-height:1.5; margin-bottom:8px; font-family:'Trebuchet MS',sans-serif; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
