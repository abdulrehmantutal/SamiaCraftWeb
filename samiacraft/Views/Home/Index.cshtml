                                             alt="@item.Name"
                                             style="width:100%; height:100%; object-fit:cover; display:block; padding:8px; border-radius:18px;"
                                             onerror="this.src='/Content/assets/images/NA.png'" />
                                    </a>
                                    @if (naDiscount > 0)
                                    {
                                        <div style="position:absolute; top:10px; left:10px; background:#F1A502; color:#fff; font-size:11px; font-weight:700; padding:3px 10px; border-radius:50px; font-family:'Trebuchet MS',sans-serif;">
                                            @naDiscount% OFF
                                        </div>
                                    }
                                </div>

                                <!-- Right: Content -->
                                <div style="padding:12px 12px 8px; flex:1; display:flex; flex-direction:column; justify-content:center; overflow:hidden; min-width:0;">

                                    <!-- ✅ Category + Rating -->
                                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
