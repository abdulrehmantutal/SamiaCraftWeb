            }

        .header-top-area {
            font-size: 12px;
        }

        .occasion h2 {
            font-size: 26px;
            line-height: 32px;
        }


        .category-circle {
            width: 80px;
            height: 80px;
        }

        .Feature-tiem > a img, .product-image > a img {
            height: auto;
