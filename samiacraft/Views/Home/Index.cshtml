        }

        .hero-slider-one .buttons .prod-btn {
            font-size: 12px;
            margin: 10px 0 0 10px;
        }

        .hero-slider .single-slide .slider-text-info .badge {
            font-size: 10px;
        }


            .hero-slider .single-slide .slider-text-info .badge img {
