        }

        .mView {
            width: 50% !important;
        }

        .mobCat {
            height: 135px !important;
        }

        .mobCatImg {
            -ms-flex: 0 0 50%;
            -webkit-box-flex: 0;
            flex: 0 0 50%;
            max-width: 50%;
        }
    }

    @@media (min-width: 375px) {
        .mobileSlide {
            display: block !important;
        }

        .pt-40 {
            padding-top: 15px;
        }

        .mob {
