<style>
    /* ✅ Dots style - figma jaisa */
    .testimonial-new-slider .slick-dots {
        bottom: -35px;
        display: flex !important;
        justify-content: center;
        align-items: center;
        gap: 6px;
        list-style: none;
        padding: 0;
        margin-top: 20px;
    }
    .testimonial-new-slider .slick-dots li button:before {
        display: none;
    }
    .testimonial-new-slider .slick-dots li button {
        width: 32px;
        height: 8px;
        border-radius: 50px;
        background: #ccc;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: background 0.3s, width 0.3s;
        font-size: 0 !important;  /* ✅ number hide */
        line-height: 0 !important;
    }
    .testimonial-new-slider .slick-dots li.slick-active button {
        background: #1C3D5A;
        width: 40px;
    }
    /* Hide arrows */
    .testimonial-new-slider .slick-prev,
    .testimonial-new-slider .slick-next { display: none !important; }
</style>

<script>
    $(document).ready(function () {
        // ✅ Destroy if already initialized (prevent double init)
        if ($('.testimonial-new-slider').hasClass('slick-initialized')) {
            $('.testimonial-new-slider').slick('destroy');
        }
        $('.testimonial-new-slider').slick({
            slidesToShow: 2,
            slidesToScroll: 1,
            arrows: false,
            dots: true,
            infinite: true,
            autoplay: true,
            autoplaySpeed: 3500,
            responsive: [
                { breakpoint: 768, settings: { slidesToShow: 1 } }
            ]
        });
    });
</script>

