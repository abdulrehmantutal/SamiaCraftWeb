<section class="occasion py-5 text-center" style="background-color: #fff;">
    <h2 class="fw-bold mb-4">
        Shop By <span class="gradient-text">Categories</span>
    </h2>
    <div class="container">
        <div class="category-slider">
            @if (ViewBag.categoryList != null && ViewBag.categoryList.Count > 0)
            {
                @foreach (var item in ViewBag.categoryList)
                {
                    <div style="padding: 20px 10px;">
                        <a href="@Url.Action("shop", "shop", new {
                              Category = "",
                              CategoryIDs = item.ID,
                              SubCategoryIDs = "",
                              ColorIDs = "",
                              MinPrice = "BHD0",
                              MaxPrice = "BHD500",
                              Searchtext = "",
                              SortID = 0
                              })" class="text-decoration-none">
                            <div class="category-circle mx-auto d-flex align-items-center justify-content-center shadow-sm overflow-hidden">
                                @if (item != null && !string.IsNullOrEmpty(item.Image))
                                {
                                    var imageBase = Configuration["Image"];
                                    var imageSrc = !string.IsNullOrEmpty(imageBase) ? imageBase + item.Image : item.Image;
                                    <img src="@imageSrc"
                                         alt="@(item.Name ?? "Category")"
                                         class="img-fluid" style="max-width:100%; max-height:100%;" />
                                }
                                else
                                {
                                    <img src="~/Content/assets/images/NA.png"
                                         alt="@(item.Name ?? "Category")"
                                         class="img-fluid" style="max-width:70%; max-height:70%;" />
                                }
                            </div>
                            <span class="d-block mt-2 text-dark fw-medium" style="font-size:13px;">@(item.Name ?? "Category")</span>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<style>
    /* Dots hide */
    .category-slider .slick-dots { display: none !important; }
    /* ✅ Arrows hide */
    .category-slider .slick-prev,
    .category-slider .slick-next { display: none !important; }
</style>

<script>
    $(document).ready(function () {
        if ($('.category-slider').hasClass('slick-initialized')) {
            $('.category-slider').slick('destroy');
        }
        $('.category-slider').slick({
            slidesToShow: 6,
            slidesToScroll: 2,
            arrows: false,      // ✅ No arrows
            dots: false,
            infinite: true,
            autoplay: true,
            autoplaySpeed: 2500,
            responsive: [
                { breakpoint: 1200, settings: { slidesToShow: 5, slidesToScroll: 2 } },
                { breakpoint: 992,  settings: { slidesToShow: 4, slidesToScroll: 2 } },
                { breakpoint: 768,  settings: { slidesToShow: 3, slidesToScroll: 1 } },
                { breakpoint: 480,  settings: { slidesToShow: 2, slidesToScroll: 1 } }
            ]
        });
    });
</script>

