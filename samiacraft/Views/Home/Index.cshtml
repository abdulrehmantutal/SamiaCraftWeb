    .mb-4, .my-4 {
        margin-bottom: 0.5rem !important;
    }

    .categorybox img {
        border-radius: 20px;
        height: 220px;
        width: 220px;
        margin: auto;
    }

    .zoom {
        transition: transform .5s;
        margin: 0 auto;
    }

        .zoom:hover {
            -ms-transform: scale(3.5);
            -webkit-transform: scale(3.5);
            transform: scale(1.1);
        }

    .all-product-image {
        padding-left: 0rem !important;
        padding-right: 0rem !important;
    }

    .product-image > a img {
        height: 275px;
        object-fit: fill;
    }

    .add-button {
        margin-top: -5px !important;
        background-color: var(--addbutton);
        border: none;
        border-radius: 50%;
        color: white;
        font-weight: 500;
        cursor: pointer;
        padding: 7px 15px;
        transition: background-color 0.3s ease-in-out;
    }

    .add-Slide-button {
        margin-top: 5% !important;
        background-color: var(--addbutton);
        border: none;
        border-radius: 50%;
        color: white;
        font-weight: 500;
        cursor: pointer;
        padding: 7px 15px;
        transition: background-color 0.3s ease-in-out;
    }

        .add-Slide-button:hover {
            background-color: white;
            border: 2px solid var(--addbutton);
        }

            .add-Slide-button:hover .add-icon {
                color: black;
            }

    .add-button:hover {
        background-color: white;
        border: 1px solid var(--addbutton);
    }

        .add-button:hover .add-icon {
            color: black;
        }

    .imgcon {
        position: relative;
        display: inline-block; /*add this to make container wrap around image*/
    }

        .imgcon img {
