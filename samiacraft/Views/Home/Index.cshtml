                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="#F1A502">
                                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                            </svg>
                                            4.9
                                        </span>
                                    </div>

                                    <!-- Product Name -->
                                    <h6 style="font-size:13px; font-weight:700; color:#1a1a1a; margin-bottom:5px; font-family:'Segoe UI',sans-serif; line-height:1.3; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @item.Name
                                    </h6>

                                    <!-- Price -->
                                    <div style="margin-bottom:5px;">
                                        @if (item.NewPrice != null && item.NewPrice > 0)
                                        {
                                            <span style="font-size:13px; font-weight:700; color:#1C3D5A; font-family:'Segoe UI',sans-serif;">BHD @item.NewPrice?.ToString("0.00")</span>
