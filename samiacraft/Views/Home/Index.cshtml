        }

        .hero-slider-one .slider-text-info p {
            font-size: 10px;
            line-height: 18px;
        }
    }

    @@media (max-width: 768px) {
        .desktop-banner {
            display: none;
        }

        .mobile-banner {
            display: block;
        }
    }

    @@media (min-width: 768px) {
        .col-md-3 {
            -ms-flex: 0 0 25%;
            -webkit-box-flex: 0;
            flex: 0 0 25%;
            max-width: 100%;
        }
    }

    @@media (min-width: 768px) {
        .mobileSlide {
            display: block !important;
        }

        .pt-40 {
            padding-top: 15px;
        }

        .mob {
            padding-bottom: 0em;
            margin-bottom: 0.2rem;
        }

        .mobview {
            padding-top: 0px;
            text-align: right;
        }

        .mView {
            width: 50% !important;
        }

        .mobCatImg {
            -ms-flex: 0 0 50%;
            -webkit-box-flex: 0;
            flex: 0 0 50%;
            max-width: 50%;
        }
    }

    @@media (max-width: 576px) {
        .main-heading {
            font-size: 1.8rem;
        }

        .instagram-grid img {
            height: 120px;
        }

        .weekly-deals-section {
            padding: 40px 15px;
        }

        .deals-content {
            padding: 30px 20px;
        }

        .deals-title,
        .deals-subtitle {
            font-size: 1.8rem;
        }

        .deals-label {
            font-size: 16px;
        }

        .deals-description {
