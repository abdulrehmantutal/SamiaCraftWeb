@using samiacraft.Models.BLL
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>@ViewBag.Title - Samia Crafts</title>
    <meta name="robots" content="index, follow" />
    <meta charset="UTF-8">
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="description" content="">
    @if (!string.IsNullOrEmpty(ViewBag.CanonicalUrl))
    {
        <link rel="canonical" href="@ViewBag.CanonicalUrl" />
    }
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="https://samiacrafts.com/assets/images/logo.svg">
    <link href="~/Content/assets/sweetalert/sweetalert.css" rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/Content/assets/css/vendor/bootstrap.min.css">

    <!-- Icon Font CSS -->
    <link rel="stylesheet" href="~/Content/assets/css/vendor/ionicons.min.css">

    <!-- Plugins CSS -->
    <link rel="stylesheet" href="~/Content/assets/css/plugins/slick.css">
    <link rel="stylesheet" href="~/Content/assets/css/plugins/animation.css">
    <link rel="stylesheet" href="~/Content/assets/css/plugins/jqueryui.min.css">
    <link href="~/Content/assets/css/plugins/flag-icon.min.css" rel="stylesheet" />


    <!-- Swipper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- CSS-->
    <link rel="stylesheet" href="~/Content/assets/css/style.css">
    <!-- jQuery JS -->

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet">
    <script src="~/Content/assets/js/vendor/jquery-3.3.1.min.js"></script>
    <script src="~/Content/assets/js/custom.js"></script>
    @{
        var headertoparea = ViewBag.TopheaderArea ?? "#1C3D5A";
        var addbutton = ViewBag.AddButton ?? "#1C3D5A";
        var workflow = ViewBag.BgWorkflow ?? "/images/bg-workflow.jpg";
        var featured = ViewBag.BgFeaturedProduct ?? "/images/bg-featured.jpg";
        var popular = ViewBag.BgPopularProduct ?? "/images/bg-popular.jpg";
        var newsletter = ViewBag.BgNewsletter ?? "/images/bg-newsletter.jpg";
        var newarrival = ViewBag.BgNewArrivals ?? "/images/bg-new-arrivals.jpg";
        var testimonial = ViewBag.BgTestimonials ?? "/images/bg-testimonials.jpg";
        var logo = ViewBag.Logo ?? "/images/logo.png";
    }


    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-35G8V97V5F"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-35G8V97V5F');
    </script>
    <style>
        :root {
            --headertoparea: @(headertoparea) !important;
            --logo: url('@(logo)');
            --bgworkflow: url('@(workflow)');
            --bgfeaturedproduct: url('@(featured)');
            --bgpopularproduct: url('@(popular)');
            --bgnewarrivals: url('@(newarrival)');
            --bgtestimonials: url('@(testimonial)');
            --bgnewsletter: url('@(newsletter)');
            --addbutton: @(addbutton);
        }

        .btn-default-opposite {
            color: white !important;
            background-color: var(--addbutton);
            border-color: var(--addbutton);
        }

            .btn-default-opposite:hover {
                color: var(--addbutton);
                background-color: #ffffff !important;
                border-color: var(--addbutton);
            }

        .nav-bg {
            background-color: white !important;
            transition: .3s all ease-out;
        }

        @@media only screen and (max-width: 479px) {
            .container-topheader {
                width: 100% !important;
            }
        }

        .prod-detail img {
            height: auto;
            width: 100%;
            object-fit: contain;
            margin: auto;
        }

        @@media only screen and (max-width: 480px) {
            .Feature-tiem > a img, .product-image > a img {
                height: auto;
                min-height: 165px;
                max-height: 165px;
            }

            .shop-item > a img {
                height: auto !important;
                min-height: 165px;
                max-height: 165px;
            }
        }

        .hovereffect {
            width: 100%;
            overflow: hidden;
            position: relative;
            text-align: center;
            cursor: default;
            border-radius: 5px;
        }

            .hovereffect:hover img {
                -ms-transform: scale(2.2);
                -webkit-transform: scale(2.2);
                transform: scale(2.2);
            }

            .hovereffect img {
                display: block;
                position: relative;
                -webkit-transition: all .4s linear;
                transition: all 1.2s linear;
            }

        #cart-total {
            background: var(--addbutton);
        }

        .newsletter-footer .subscribe-btn {
            background: var(--addbutton);
        }

        .btn-newsletter {
            background: var(--addbutton);
            border: 1px solid var(--addbutton);
        }

        .text-default {
            color: var(--addbutton);
        }

        .main-menu-area ul > li:first-child {
            color: #B4A950;
        }

        #scrollUp {
            background-color: var(--addbutton);
        }

        .breadcrumb-area h2 {
            color: var(--addbutton);
        }

        .breadcrumb-list .breadcrumb-item.active {
            color: var(--addbutton);
        }

        a:hover {
            color: var(--addbutton);
        }

        .product-rating li {
            color: var(--addbutton);
        }

        .mini-cart-btns .cart-btns a {
            background: var(--addbutton);
            border: 2px solid var(--addbutton);
        }

            .mini-cart-btns .cart-btns a:hover {
                background: white;
                border: 2px solid var(--addbutton);
                color: var(--addbutton);
            }

        .fill {
            color: var(--addbutton);
        }

            .fill:hover {
                color: red;
            }

        .imgcon .wl {
            position: absolute;
            top: 0;
            right: 0;
            z-index: 2; /* add this to make icon stack over image */
            margin-right: 8px;
            margin-top: 8px;
            border: 1px solid var(--addbutton);
            justify-content: center;
            border-radius: 50%;
            height: 30px;
            width: 30px;
            padding-top: 1%;
        }

        .social-top ul {
            list-style: none; /* remove bullets */
            margin: 0;
            padding: 0;
            display: flex; /* align in one row */
            justify-content: flex-end; /* push them to right */
            gap: 10px;
        }

            .social-top ul li {
                display: inline-block;
                margin-right: 2px !important;
            }

        .parent {
            height: 100vh;
        }

            .parent > .row {
                display: flex;
                align-items: center;
                height: 100%;
            }

        .col img {
            height: 100px;
            width: 100%;
            cursor: pointer;
            transition: transform 1s;
            object-fit: cover;
        }

        .col label {
            overflow: hidden;
            position: relative;
        }

        .imgbgchk:checked + label > .tick_container {
            opacity: 1;
        }
        /*         aNIMATION */
        .imgbgchk:checked + label > img {
            transform: scale(1);
            opacity: 0.3;
        }

        .tick_container {
            transition: .5s ease;
            opacity: 0;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            -ms-transform: translate(-50%, -50%);
            cursor: pointer;
            text-align: center;
        }

        .tick {
            background-color: #4CAF50;
            color: white;
            font-size: 16px;
            padding: 6px 12px;
            height: 40px;
            width: 40px;
            border-radius: 100%;
        }

        .image-container {
            margin-bottom: 10px; /* Adjust the margin as needed */
        }

            .image-container img {
                max-width: 100%; /* Make sure the image doesn't exceed its container */
            }


        .figure {
            position: relative;
            /*width: 360px;*/ /* can be omitted for a regular non-lazy image */
            max-width: 100%;
        }

            .figure img.Sirv.image-hover {
                position: absolute;
                top: 0;
                right: 0;
                left: 0px;
                bottom: 0;
                object-fit: contain;
                opacity: 0;
                transition: opacity .2s;
            }

            .figure:hover img.Sirv.image-hover {
                opacity: 1;
            }



        #popupModal {
            /*background-color: transparent;*/
            backdrop-filter: blur(70px);
        }

        .modal-content {
            background-color: rgba(255, 255, 255, 0.8); /* Add a semi-transparent background for better readability */
            backdrop-filter: blur(10px); /* Adjust the blur intensity as needed */
            border: 1px solid rgba(255, 255, 255, 0.8); /* Add a border to enhance visibility */
        }

        /* Other styles remain unchanged */


        @@media only screen and (max-width: 480px) {
            .citymobile {
                padding-top: 50px !important;
                padding-bottom: 50px !important;
            }

            .figure img.Sirv.image-hover {
                position: absolute;
                top: 0;
                right: 0;
                left: 0px;
                bottom: 0;
                object-fit: contain;
                opacity: 0;
                transition: opacity .2s;
                height: 50px;
            }

            .image-container img {
                max-width: 90%;
            }

            .citycol {
                width: 33.33%;
            }

            .cityvw {
                font-size: 15px !important;
            }
        }

        .modal-dialog {
            min-height: calc(100vh - 60px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: auto;
        }

        @@media(max-width: 768px) {
            .modal-dialog {
                min-height: calc(100vh - 20px);
            }
        }

        @@media (min-width: 992px) {
            .hidedesktop {
                display: none !important;
            }
        }

        /* Sticky Header Styles */
        .fl-header {
            transition: all 0.3s ease-out;
        }

            .fl-header.nav-fixed-top {
                position: fixed;
                z-index: 1000;
                width: 100%;
                top: 0;
                left: 0;
                right: 0;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }

                .fl-header.nav-fixed-top .haeader-bottom-area {
                    background: white;
                    border-bottom: 1px solid #154a901a;
                }

        /* Prevent flash of unstyled content */
        body {
            transition: padding-top 0.3s ease-out;
        }

        .footer-list:hover li a {
            color: #fff !important;
        }

        .footer-contact:hover li a {
            color: #fff !important;
        }
    </style>

</head>
<body>

    <header class="fl-header" id="mainHeader">
        <!-- Header Top Start -->
        <div class="header-top-area " style="background: var(--headertoparea)">
            <div class="container container-topheader">
                <div class="row">
                    <div class="col-lg-1 d-none d-lg-block">
                        <div class="social-top">
                            <ul>
                                <li id="facebook" class=""><a><img src="/Content/assets/images/icon/fb.png" /></a></li>
                                <li id="instagram" class=""><a><img src="/Content/assets/images/icon/ins.png" /></a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-5 align-self-center text-center">
                        <p class="m-0 small text-uppercase" id="TopHeaderText" style="color:white; line-height:15px;">Discover Beautiful Handmade Crafts & Timeless Art</p>
                    </div>
                    <div class="col-lg-3 text-center">
                        <div class="social-top">
                            <ul>
                                <li id="" class="">
                                    <img src="/Content/assets/images/icon/cod.png">
                                </li>
                                <li id="" class="">
                                    <img src="/Content/assets/images/icon/bank-transfer.png">
                                </li>
                                <li id="" class="">
                                    <img src="/Content/assets/images/icon/visa.png">
                                </li>
                                <li id="" class="">
                                    <img src="/Content/assets/images/icon/master.png">
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-3 text-center">
                        @* <div class="social-top">
                            <ul>
                                <li id="" class="">
                                    <a style="font-size: 14px;cursor: pointer;padding: 4px 15px;" class="bold border border-dark btn btn-default-opposite shadow-sm" id="cityClick"><i class="ion-location ml-1"></i> <span>Select City</span></a>
                                </li>
                                <li class="hidedesktop">
                                    <a style="font-size: 14px;cursor: pointer;padding: 4px 15px;" class="bold border border-dark btn btn-default-opposite shadow-sm" data-toggle="modal" data-target="#exampleModalCenter"><i class="ion-android-list"></i> <span>Category</span></a>
                                </li>
                            </ul>
                        </div> *@
                    </div>
                </div>
            </div>
        </div>
        <!-- Header Top End -->
        <!-- haeader bottom Start -->
        <div class="haeader-bottom-area nav-bg" id="Head">
            <div class="container w-100">
                <div class="row align-items-center">
                    <div class="col-lg-2 col-md-4 col-5">
                        <div class="logo-area">
                            <a href="~/home/index">
                                <img class="main-logo" src="https://samiacrafts.com/assets/images/logo.svg" alt="">
                            </a>
                        </div>
                    </div>
                    <div class="col-lg-8 d-none d-lg-block">
                        <div class="main-menu-area text-center">
                            @* @await Html.Action("Header", "Shared") *@
                            @await Component.InvokeAsync("MobileNavigation")
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-8 col-7">
                        <div class="right-blok-box d-flex">
                            <div class="search-wrap">
                                <a href="#" class="trigger-search"><i class="ion-ios-search-strong"></i></a>
                            </div>

                            <div class="user-wrap">
                                <a href="~/product/wishlist"><i class="ion-android-favorite-outline"></i></a>
                            </div>

                            <div class="shopping-cart-wrap">
                                <a href="~/order/cart">
                                    <img src="~/Content/assets/images/shopping-cart.png" width="23px" /> <span id="cart-total">0</span>
                                </a>
                                <ul class="mini-cart head-cart ">
                                </ul>
                            </div>
                            <div class="login-icon ">
                                @if (@Context.Session.GetString("CustomerName") != null)
                                {
                                    <a href="" dropdown-toggle" data-toggle="dropdown"><i class="ion-ios-contact"></i></a>
                                    <div class="dropdown-menu alignment p-0 mt-0">
                                        <a class="dropdown-item border-bottom text-center" style="font-size:12px;" href="#"><span class="font-weight-bold">Hi!</span> @Context.Session.GetString("CustomerName")</a>
                                        <a href="~/Order/Myorders" class="about-bg border-bottom dropdown-item font-weight-bold py-4 text-center" style="font-size:12px;">My Orders</a>
                                        <a class="dropdown-item text-center " style="font-size:12px;" href="~/account/logout">Logout</a>
                                    </div>
                                }
                                else
                                {
                                    <a href="~/account/Login_Register?id=1"><i class="ion-ios-contact"></i></a>
                                }

                            </div>
                            <div class="mobile-menu-btn d-block d-lg-none">
                                <div class="off-canvas-btn">
                                    <i class="ion-android-menu">
                                    </i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- haeader bottom End -->
        <!-- Inline Search Bar -->
        <div id="searchBar" class="search-bar-container" style="display: none; background: rgba(28, 61, 90, 0.8); padding: 30px 0; position: relative; z-index: 999;">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <form id="searchForm" style="width: 100%; margin: 0;">
                                <div style="display: flex; align-items: center; position: relative;">
                                    <input type="text" id="search" class="form-control" placeholder="Search Entire Store" style="border: none; background: transparent; color: #999; font-size: 18px; padding: 15px 0;">
                                    <button class="close-search-bar" type="button" style="background: none; border: none; font-size: 32px; cursor: pointer; color: white; margin-left: auto; padding: 0 15px;">×</button>
                                </div>
                            </form>
                            <button class="btn-search-icon" type="button" id="search-btn" style="background: none; border: none; cursor: pointer; color: #999; font-size: 24px; margin-left: 15px;">
                                <i class="ion-ios-search-strong"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-block d-lg-none">
            @await Component.InvokeAsync("MobileNavigation")
        </div>
    </header>

    <div class="main-wrapper">
        @RenderBody()
    </div>
