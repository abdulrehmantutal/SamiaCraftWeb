    <script>
        $(document).ready(function () {
            var cityID = getCookieValue("CityID");
            var cityName = getCookieValue("CityName");

            if (cityID && cityName) {

                $('#cityClick span').text(cityName);
                $('#popupModal').modal('hide');
                console.log("cookie exist");

            } else {

                $('#popupModal').modal({
                    backdrop: 'static',
                    keyboard: false
                });
                $('#popupModal').modal('show');
            }

            function getCookieValue(name) {

                var value = "; " + document.cookie;
                var parts = value.split("; " + name + "=");

                if (parts.length === 2) {
                    return parts.pop().split(";").shift();
                } else {
                    return null; // Cookie not found or empty
                }
            }
            // Handle radio button selection
            $('input[name="radioOptions"]').change(function () {
                // Get the selected value

                var CityID = $('input[name="radioOptions"]:checked').val();
                document.cookie = "CityID=" + CityID + "; path=/";
                document.cookie = "CityName=" + $(`label[for="${CityID}"] .city-name`).text() + "; path=/";


                var selectedCityName = $(`label[for="${CityID}"] .city-name`).text();

                // Update modal title
                $('#popupModal .modal-title').text(selectedCityName);

                // Update button text

                var storedCityName = getCookieValue("CityName");
                function getCookieValue(name) {
                    var value = "; " + document.cookie;
                    var parts = value.split("; " + name + "=");

                    if (parts.length === 2) {
                        return parts.pop().split(";").shift();
                    } else {
                        return null; // Cookie not found or empty
                    }
                }

                $('#cityClick span').text(storedCityName);

                $('#popupModal').modal('hide');
                window.location.href = '/Home/Index';



            });
        });

    </script>
