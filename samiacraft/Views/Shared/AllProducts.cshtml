        }

    }

    @@media (min-width: 1024px) {

        .product-content {
            padding-top: 0px !important;
            padding-left: 0px !important;
        }

        @@media (min-width: 768px) {
            .col-md-3 {
                -ms-flex: 0 0 25%;
                -webkit-box-flex: 0;
                flex: 0 0 25%;
